{
  "id": "blockli-cache-proxy",
  "name": "Blockli Cache Proxy",
  "description": "Go HTTP cache proxy backed by Redis. Used by the Blockli Mobile App Bunny Edge Script to cache WordPress REST API responses at the edge.",
  "icon": "code",
  "containers": [
    {
      "name": "app",
      "imageNamespace": "library",
      "imageName": "golang",
      "imageTag": "1.25-alpine",
      "environmentVariables": [
        {
          "key": "REDIS_URL",
          "value": "redis://localhost:6379"
        },
        {
          "key": "CACHE_API_TOKEN",
          "value": ""
        },
        {
          "key": "PORT",
          "value": "8080"
        }
      ],
      "volumes": [],
      "endpoints": [
        {
          "displayName": "HTTP",
          "type": "CDN",
          "containerPort": 8080
        }
      ]
    },
    {
      "name": "redis",
      "imageNamespace": "library",
      "imageName": "redis",
      "imageTag": "7-alpine",
      "environmentVariables": [],
      "volumes": [
        {
          "mountPath": "/data",
          "sizeMB": 256
        }
      ],
      "endpoints": []
    }
  ]
}
